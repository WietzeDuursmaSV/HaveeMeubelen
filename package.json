{
  "name": "havee-beeldbank",
  "version": "1.0.0",
  "description": "Havee Beeldbank - ExpressionEngine CMS with Tailwind CSS",
  "main": "index.js",
  "scripts": {
    "build-css": "sass themes/user/site/default/asset/css/input.scss | tailwindcss -i - -o themes/user/site/default/asset/css/global.css --watch",
    "build-css-prod": "sass themes/user/site/default/asset/css/input.scss | tailwindcss -i - -o themes/user/site/default/asset/css/global.css --minify"
  },
  "keywords": [
    "expressionengine",
    "tailwindcss",
    "beeldbank",
    "cms"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.27",
    "sass": "^1.99.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-scss": "^6.0.0",
    "tailwindcss": "^3.4.0"
  }
}
